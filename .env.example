# Site codes: B2B, B2C, VAP, PCH
# Each migration run targets one Shopify store → one BigCommerce store pair.
# Pass the site code as { "site": "B2B" } in every API request body or query param.

# ── Shopify ──────────────────────────────────────────────────
# Token per store — matches mipod-shopifyql site config:
#   B2B → mi-one-com.myshopify.com
#   B2C → smoking-vapor-consumer.myshopify.com
#   VAP → vaping-usa.myshopify.com
#   PCH → mi-pouches.myshopify.com

SHOPIFY_API_VERSION=2026-04

B2B_TOKEN=your_b2b_shopify_token
B2C_TOKEN=your_b2c_shopify_token
VAP_TOKEN=your_vap_shopify_token
PCH_TOKEN=your_pch_shopify_token

# ── BigCommerce ──────────────────────────────────────────────
# One store hash + access token per site code.

B2B_BIGCOMMERCE_STORE_HASH=your_b2b_store_hash
B2B_BIGCOMMERCE_CLIENT_ACCESS_TOKEN=your_b2b_access_token

B2C_BIGCOMMERCE_STORE_HASH=your_b2c_store_hash
B2C_BIGCOMMERCE_CLIENT_ACCESS_TOKEN=your_b2c_access_token

VAP_BIGCOMMERCE_STORE_HASH=your_vap_store_hash
VAP_BIGCOMMERCE_CLIENT_ACCESS_TOKEN=your_vap_access_token

PCH_BIGCOMMERCE_STORE_HASH=your_pch_store_hash
PCH_BIGCOMMERCE_CLIENT_ACCESS_TOKEN=your_pch_access_token

# ── Logger (optional) ────────────────────────────────────────
LOG_LEVEL=info
LOG_COLORS=true
LOG_TIMESTAMPS=true
