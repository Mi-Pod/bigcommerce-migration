  "item": [
    {
      "name": "Migration Workflow — B2C",
      "item": [
        {
          "name": "Step 1 — Verify BC Connection",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/test/bigcommerce?site=B2C",
              "host": ["{{baseUrl}}"],
              "path": ["api", "test", "bigcommerce"],
              "query": [{ "key": "site", "value": "B2C" }]
            }
          }
        },
        {
          "name": "Step 2 — Fetch All Shopify Collections",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/shopify/collections?site=B2C",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "shopify", "collections"],
              "query": [{ "key": "site", "value": "B2C", "description": "Writes shopify-collections.json — required by Steps 5 and 6" }]
            }
          }
        },
        {
          "name": "Step 3 — Extract Nav (Desktop: dsk-nav-21)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/navigation/dsk-nav-21?site=B2C",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "navigation", "dsk-nav-21"],
              "query": [
                { "key": "site", "value": "B2C", "description": "Writes nav-dsk-nav-21.json — required by Step 5" },
                { "key": "menuId", "value": "179918012479", "description": "Shopify numeric menu ID — required if this handle isn't in KNOWN_MENUS for this site", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Step 4 — Extract Nav (Mobile: sidebar-menu)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/navigation/sidebar-menu?site=B2C",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "navigation", "sidebar-menu"],
              "query": [
                { "key": "site", "value": "B2C", "description": "Writes nav-sidebar-menu.json — required by Step 5" },
                { "key": "menuId", "value": "113748344895", "description": "Shopify numeric menu ID — required if this handle isn't in KNOWN_MENUS for this site", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Step 5 — Build Nav Collection Map",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/shopify/nav-collection-map?site=B2C",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "shopify", "nav-collection-map"],
              "query": [{ "key": "site", "value": "B2C", "description": "Needs Steps 2–4. Writes nav-collection-map.json — required by Step 6" }]
            }
          }
        },
        {
          "name": "Step 6 — Build Collection Visibility Map",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/shopify/collection-visibility-map?site=B2C",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "shopify", "collection-visibility-map"],
              "query": [{ "key": "site", "value": "B2C", "description": "Needs Steps 2 and 5. Writes collection-visibility-map.json — required by product migration" }]
            }
          }
        },
        {
          "name": "Step 7 — Count Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/products/count?site=B2C",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "products", "count"],
              "query": [{ "key": "site", "value": "B2C" }]
            }
          }
        },
        {
          "name": "Step 8 — Migrate Single Product (test run)",
