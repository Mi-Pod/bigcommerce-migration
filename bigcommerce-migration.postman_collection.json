              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/migrate/products/bulk",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "products", "bulk"]
            }
          }
        },
        {
          "name": "Step 11 — Count Customers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/customers/count?site=B2C",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "customers", "count"],
              "query": [{ "key": "site", "value": "B2C" }]
            }
          }
        },
        {
          "name": "Step 12 — Migrate Single Customer (test run)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"site\": \"B2C\",\n  \"shopifyCustomerId\": \"2147081748549\",\n  \"save\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/migrate/customers/single",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "customers", "single"]
            }
          }
        },
        {
          "name": "Step 13 — Bulk Migrate Customers",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"site\": \"B2C\",\n  \"batch_size\": 50,\n  \"skip\": 0,\n  \"max_batches\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/migrate/customers/bulk",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "customers", "bulk"]
            }
          }
        },
        {
          "name": "Step 14 — Compose BC Navigation Payload",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/navigation/compose",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "navigation", "compose"]
            }
          }
        },
        {
          "name": "Step 15 — Compare Navigation (BC vs Composed)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/navigation/compare",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "navigation", "compare"]
            }
          }
        },
        {
          "name": "Step 16 — Migrate Navigation to BC",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"site\": \"B2C\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/migrate/navigation/migrate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "navigation", "migrate"]
            }
          }
        },
        {
          "name": "Step 17 — Validate Navigation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate/navigation/validate?site=B2C",
              "host": ["{{baseUrl}}"],
              "path": ["api", "migrate", "navigation", "validate"],
              "query": [{ "key": "site", "value": "B2C" }]
            }
          }
        }
      ]
